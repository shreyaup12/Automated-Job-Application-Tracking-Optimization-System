      "parameters": {
        "jsCode": "const emailData = $item(0).$node[\"Code in JavaScript3\"].json || {};\n\nconst emailCompany = (emailData.company || \"\").toLowerCase();\nconst emailStatus = emailData.status;\n\nconst notionItems = $input.all();\n\nlet match = null;\n\nfor (let notion of notionItems) {\n  const company = (notion.json.property_company || \"\").toLowerCase();\n\n  if (company === emailCompany) {\n    match = notion;\n    break;\n  }\n}\n\n// ❌ nothing to match → stop\nif (!match || !emailCompany || !emailStatus) return null;\n\nreturn {\n  json: {\n    pageId: match.json.id,\n    status: emailStatus\n  }\n};"
