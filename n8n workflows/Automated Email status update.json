    {
      "parameters": {
        "jsCode": "const subject = ($json.Subject || \"\").toLowerCase();\nconst from = $json.From || \"\";\nconst body = ($json.snippet || \"\").toLowerCase();\n\nlet status = \"\";\n\n// STATUS DETECTION\nif (subject.includes(\"interview\") || body.includes(\"interview\")) {\n  status = \"Interview\";\n} \nelse if (subject.includes(\"offer\")) {\n  status = \"Offer\";\n} \nelse if (\n  subject.includes(\"rejected\") ||\n  subject.includes(\"not selected\") ||\n  body.includes(\"unfortunately\")\n) {\n  status = \"Rejected\";\n}\n\n// ❌ ignore if no status\nif (!status) return null;\n\n\n// COMPANY EXTRACTION\nlet company = \"\";\n\n// 1. from subject (best)\nconst match = subject.match(/at ([a-zA-Z]+)/);\nif (match) {\n  company = match[1];\n}\n\n// 2. fallback from body\nif (!company) {\n  const bodyMatch = body.match(/regards,\\s*([a-zA-Z ]+)/);\n  if (bodyMatch) {\n    company = bodyMatch[1].trim();\n  }\n}\n\n// 3. fallback from email\nif (!company) {\n  const emailMatch = from.match(/<(.+?)>/);\n  const email = emailMatch ? emailMatch[1] : from;\n  company = email.split(\"@\")[1]?.split(\".\")[0] || \"\";\n}\n\n// clean\ncompany = company.toLowerCase();\n\nreturn {\n  json: {\n    status,\n    company\n  }\n}; "
      },
