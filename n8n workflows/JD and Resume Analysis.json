{
  "name": "JD and Resume Analysis",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n\n  const jd = item.json.JD || \"\";   \n\n  const resume_url =\n    Array.isArray(item.json.Resume)\n      ? item.json.Resume[0]        \n      : item.json.Resume || \"\";\n\n  if (!jd || !resume_url) {\n    return {\n      json: {\n        pageId: item.json.id,\n        skip: true,\n        error: \"Missing JD or Resume URL\",\n        debug: {\n          jd,\n          resume: item.json.Resume\n        }\n      }\n    };\n  }\n\n  return {\n    json: {\n      jd,\n      resume_file: resume_url,\n      pageId: item.json.id\n    }\n  };\n});"
      },
